{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/ui/*"],
      "@data/*": ["./src/data/*"]
    }
  },
  "include": ["src/ui/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "scripts"]
}
