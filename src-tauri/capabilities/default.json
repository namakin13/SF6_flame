{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "SF6 Frame Viewer default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "shell:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://ultimateframedata.com/**" }
      ]
    }
  ]
}
